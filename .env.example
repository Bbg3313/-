VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# 관리자 로그인: 아이디만 입력 시 붙는 도메인 (Supabase 사용자 이메일과 일치해야 함, 예: clinic → clinic@admin.yonsaemi.kr)
VITE_ADMIN_LOGIN_DOMAIN=admin.yonsaemi.kr
# 이벤트·프로모션 목록 (내부 기본 /events, 외부 게시판이면 전체 URL)
VITE_EVENT_BOARD_URL=/events
# 메인·히어로·플로팅 등 예약 CTA 목적지 (비우면 내부 /reservation)
VITE_RESERVATION_URL=
# 네이버 플레이스 예약 URL(공지·예약 페이지의 「네이버 예약」카드에만 사용)
VITE_NAVER_RESERVATION_URL=
VITE_NAVER_TALK_URL=
VITE_KAKAO_CHANNEL_URL=

